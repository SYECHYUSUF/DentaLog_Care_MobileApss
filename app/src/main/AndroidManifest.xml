<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.aditya.smartdental">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="Smart Dental"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SmartDental">

        <activity
            android:name="com.aditya.smartdental.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.aditya.smartdental.LoginActivity"
            android:exported="false" />

        <activity
            android:name="com.aditya.smartdental.MainActivity"
            android:exported="true" />

        <activity
            android:name="com.aditya.smartdental.AddEditActivity"
            android:exported="false"
            android:label="Manage Tool" />

    </application>

</manifest>